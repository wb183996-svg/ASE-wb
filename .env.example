# Environment Variables Example for ASE Platform

# Gemini API Key (Secret, Server-Side Only)
GEMINI_API_KEY=

# Cloud SQL Connection Details (Runtime App User)
SQL_HOST=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=

# Cloud SQL Migration/Admin Credentials (Drizzle Kit Admin)
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=
